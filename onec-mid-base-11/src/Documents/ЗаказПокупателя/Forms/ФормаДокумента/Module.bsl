#Область ОбработчикиСобытийЭлементовШапкиФормы
// Код процедур и функций
&НаКлиенте
Процедура ДР_СогласованнаяСкидкаПриИзменении(Элемент)
	
	Если (Объект.Товары.Количество()<> 0) Или (Объект.Услуги.Количество()<> 0) Тогда
		Режим = РежимДиалогаВопрос.ДаНет;
		Оповещение = Новый ОписаниеОповещения ("ДР_ОбработатьОтветПользователя",ЭтотОбъект);
		ПоказатьВопрос(Оповещение, "Процент скидки  изменен. Пересчитать табличную часть?", Режим);    
	КонецЕсли;

КонецПроцедуры
#КонецОбласти


#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ДР_ОбработатьОтветПользователя(Ответ, ДополнительныеПараметры) Экспорт
    	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		ДР_ПересчитатьТаблицуДокумента();
		РассчитатьСуммуДокумента();
	КонецЕсли;   
	
КонецПроцедуры
&НаКлиенте
Процедура РассчитатьСуммуСтроки(ТекущиеДанные)
	
	//Предыдущий код
	//КоэффициентСкидки = 1 - ТекущиеДанные.Скидка / 100;
	
	
	
	РазмерСкидки = ТекущиеДанные.Скидка + Объект.ДР_СогласованнаяСкидка;
	Если РазмерСкидки > 100 Тогда
		РазмерСкидки = 100;
		Сообщить ("Сумма равна 0, так как размер скидки 100%");
	КонецЕсли;
	КоэффициентСкидки = 1 - РазмерСкидки / 100;  
	
	
	ТекущиеДанные.Сумма = ТекущиеДанные.Цена * ТекущиеДанные.Количество * КоэффициентСкидки;
	

	РассчитатьСуммуДокумента();

КонецПроцедуры

&НаКлиенте
Процедура ДР_ПересчитатьТаблицуДокумента()
	Для Каждого Строка Из Объект.Товары Цикл
		РассчитатьСуммуСтроки(Строка);
	КонецЦикла;
	
	Для Каждого Строка Из Объект.Услуги Цикл
		РассчитатьСуммуСтроки(Строка);
	КонецЦикла;	
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьСуммуДокумента()
	
	Объект.СуммаДокумента = Объект.Товары.Итог("Сумма") + Объект.Услуги.Итог("Сумма");
	
КонецПроцедуры


